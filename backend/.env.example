# Conexão com o banco Supabase
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# Porta do servidor (Railway define automaticamente via PORT)
PORT=8090

# URL do projeto Supabase (para validação JWT via JWKS)
# Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Origens permitidas para CORS (separadas por vírgula)
# Adicione a URL do seu deploy Vercel aqui
# Exemplo: https://nexus-academico.vercel.app
CORS_ORIGINS=https://SEU_FRONTEND.vercel.app
